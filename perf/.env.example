# Perf Environment Configuration
# Copy this to .env and fill in the values

# --- Neon Perf Database ---
PERF_DATABASE_URL='postgresql://neondb_owner:xxx@ep-xxx-pooler.c-2.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require'
PERF_DIRECT_URL='postgresql://neondb_owner:xxx@ep-xxx.c-2.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# --- Production Database (read-only, for seeding reference data) ---
PROD_DATABASE_URL='postgresql://xxx@ep-xxx-pooler.us-east-2.aws.neon.tech/xxx?sslmode=require&channel_binding=require'

# --- Perf App URLs ---
PERF_WEB_APP_URL=https://chess-battle-perf.vercel.app
PERF_WS_URL=wss://ws-perf.playchess.tech

# --- EC2 WebSocket Server ---
EC2_HOST=3.94.8.101
EC2_USER=ubuntu
EC2_KEY_PATH=~/.ssh/chess-battle-keypair.pem

# --- Clerk (same dev instance) ---
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
